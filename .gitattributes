# Fitxers de desenvolupament que NO han d'anar dins del ZIP de distribució.
# `git archive` (local i al workflow) els exclou gràcies a export-ignore.
/.github         export-ignore
/.gitignore      export-ignore
/.gitattributes  export-ignore
/tests           export-ignore
/docs            export-ignore

# Normalitza finals de línia.
* text=auto
