msgstr "Emergency recovery:"

#: includes/views/network-settings-page.php:90
msgid "Redirect de login elegible"
msgstr "Login redirect eligible"

#: includes/views/network-settings-page.php:137
msgid "Redirigir els logins dels subsites al login del site principal"
msgstr "Redirect subsite logins to the main site's login"

