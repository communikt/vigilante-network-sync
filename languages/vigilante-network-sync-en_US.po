#: includes/views/network-settings-page.php:92
msgid "No configurat"
msgstr "Not configured"

#: includes/views/network-settings-page.php:97
msgid "Bloqueig de login elegible"
msgstr "Login blocking eligible"

#: includes/views/network-settings-page.php:101
msgid "No (xarxa de subdominis: cookie d'auth no compartida)"
msgstr "No (subdomain network: auth cookie not shared)"

#: includes/views/network-settings-page.php:103
msgid "No (cal custom-login al principal)"
msgstr "No (requires custom-login on the main site)"

#: includes/views/network-settings-page.php:105
