#: includes/class-vigsync-network-admin.php:49 includes/views/network-settings-page.php:33
msgid "Vigilante Network Sync"
msgstr "Vigilante Network Sync"

#: vigilante-network-sync.php:69
msgid "Vigilante Network Sync requereix una instal·lació WordPress multisite. Desactiva el plugin."
msgstr "Vigilante Network Sync requires a WordPress multisite installation. Deactivate the plugin."

#: includes/class-vigsync-network-admin.php:194
msgid "Vigilante Network Sync — canvi detectat a Vigilante"
msgstr "Vigilante Network Sync — change detected in Vigilante"

#: includes/class-vigsync-plugin.php:81
msgid "Vigilante Network Sync: redirect de login desactivat per seguretat"
msgstr "Vigilante Network Sync: login redirect disabled for safety"

#: includes/class-vigsync-network-admin.php:50
msgid "Vigilante Sync"
msgstr "Vigilante Sync"

#: includes/views/network-settings-page.php:61
msgid "Vigilante actiu"
msgstr "Vigilante active"

#. translators: 1: versió antiga, 2: versió nova
#: includes/class-vigsync-network-admin.php:178
msgid "Vigilante ha canviat de la versió %1$s a la %2$s."
msgstr "Vigilante has changed from version %1$s to %2$s."

#: includes/views/network-settings-page.php:46
msgid "Vigilante no està actiu en aquesta xarxa. Activa Vigilante per poder sincronitzar."
msgstr "Vigilante is not active on this network. Activate Vigilante to be able to synchronize."

#: includes/class-vigsync-sync.php:50
msgid "Vigilante no està actiu en aquesta xarxa. No s'ha sincronitzat res."
msgstr "Vigilante is not active on this network. Nothing was synchronized."

#. translators: %s: nom de la xarxa
#: includes/class-vigsync-network-admin.php:219
msgid "[%s] Vigilante ha canviat de versió"
msgstr "[%s] Vigilante has changed version"

#: includes/views/network-settings-page.php:229
msgid "configura el custom-login només al site principal, deixa'l buit als subsites i activa el login unificat. Tots els logins van al principal i el 2FA s'enrola un sol cop."
msgstr "configure the custom-login only on the main site, leave it empty on the subsites and enable the unified login. All logins go to the main site and 2FA is set up only once."

#: includes/views/network-settings-page.php:233
msgid "defineix VIGSYNC_DISABLE_REDIRECT a true al wp-config.php per desactivar el redirect sense tocar la base de dades."
msgstr "define VIGSYNC_DISABLE_REDIRECT as true in wp-config.php to disable the redirect without touching the database."

#: includes/views/network-settings-page.php:231
msgid "mateix slug a tots els sites (via sync) i redirect desactivat. Cada site amaga el seu propi login; el 2FA s'enrola per-site."
msgstr "same slug on all sites (via sync) with redirect disabled. Each site hides its own login; 2FA is set up per site."

#: includes/class-vigsync-sync.php:144
msgid "update_option ha retornat false (possible error d'escriptura)."
msgstr "update_option returned false (possible write error)."

