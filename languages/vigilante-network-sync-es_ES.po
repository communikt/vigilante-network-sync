msgid "No configurat"
msgstr "No configurado"

#: includes/views/network-settings-page.php:97
msgid "Bloqueig de login elegible"
msgstr "Bloqueo de login elegible"

#: includes/views/network-settings-page.php:101
msgid "No (xarxa de subdominis: cookie d'auth no compartida)"
msgstr "No (red de subdominios: cookie de auth no compartida)"

#: includes/views/network-settings-page.php:103
